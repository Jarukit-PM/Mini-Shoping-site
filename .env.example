# Copy to the repository root as `.env` and adjust. Docker Compose reads this file for substitution.
# Local dev: the Go API loads `.env` from the current working directory upward; Next.js reads only
# `API_URL` and `NEXT_PUBLIC_API_URL` from this file (see `apps/web/next.config.mjs`) so `PORT=8080`
# here does not override the Next dev server port.

# Go API (local or container)
PORT=8080
MONGODB_URI=mongodb://localhost:27017
# Database name for the Go API (collection namespace). Optional if you only use the host in MONGODB_URI.
MONGODB_DATABASE=mini_shop
# Comma-separated browser origins allowed by CORS (Next.js dev server and Docker web hostname)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth: sessions stored in MongoDB (`sessions` collection).
# The Go API reads these — copy this file to `.env` at the repo root (do not rely on `.env.example` alone).
# First admin is created when `users` is empty; in non-production the password for ADMIN_EMAIL is
# updated on every API startup so it always matches ADMIN_PASSWORD here (handy with Docker volumes).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
# Optional session lifetime for the opaque cookie token (hours, default 24)
# SESSION_TTL_HOURS=24
# Production cookie flags: APP_ENV=production and/or COOKIE_SECURE=true

# Checkout: flat shipping in cents added to order subtotal (Member C / Assumption A-01)
# SHIPPING_FLAT_CENTS=15000

# Next.js — server-side fetches to the API (use service name inside Docker network)
API_URL=http://localhost:8080
# Browser / client-side API base (must be reachable from the user’s machine)
NEXT_PUBLIC_API_URL=http://localhost:8080
